# Large original audio files (not for git)
samples/**/*.mp3
samples/**/*.wav
samples/**/*.m4a

# Keep trimmed and midi
!samples/trimmed/
!samples/midi/

# System files
.DS_Store
Thumbs.db
*.tmp

# Python
__pycache__/
*.pyc

# Node
node_modules/

# Logs
*.log

# Session markers (transient, created by hooks)
.sessions/

# YouTube 자동화 — 토큰/시크릿
tools/youtube/client_secret.json
tools/youtube/accounts/token_*.json
tools/youtube/uploads/done/*
!tools/youtube/uploads/done/.gitkeep
tools/youtube/community/done/*
!tools/youtube/community/done/.gitkeep
